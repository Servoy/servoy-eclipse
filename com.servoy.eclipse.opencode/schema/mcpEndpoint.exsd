<?xml version='1.0' encoding='UTF-8'?>
<!-- Schema file for com.servoy.eclipse.opencode.mcpEndpoint extension point -->
<schema targetNamespace="com.servoy.eclipse.opencode" xmlns="http://www.w3.org/2001/XMLSchema">
<annotation>
      <appinfo>
         <meta.schema plugin="com.servoy.eclipse.opencode" id="mcpEndpoint" name="Opencode MCP Endpoint Provider"/>
      </appinfo>
      <documentation>
         Extension point that lets plugins contribute MCP (Model Context Protocol) endpoint URLs
         and an optional auth token to the embedded opencode server.
         Before launching opencode, the framework collects all contributions, rewrites each URL
         to use {env:MCP_PORT} in place of the hardcoded port, and merges the resulting entries
         into opencode.json. The actual port and auth token are passed to the opencode child
         process as environment variables MCP_PORT and MCP_AUTH_TOKEN.
      </documentation>
   </annotation>

   <element name="extension">
      <annotation>
         <appinfo>
            <meta.element />
         </appinfo>
      </annotation>
      <complexType>
         <sequence>
            <element ref="endpoint" minOccurs="1" maxOccurs="unbounded"/>
         </sequence>
         <attribute name="point" type="string" use="required">
            <annotation>
               <documentation>
                  The fully qualified identifier of the target extension point.
               </documentation>
            </annotation>
         </attribute>
         <attribute name="id" type="string">
            <annotation>
               <documentation>
                  An optional identifier of the extension instance.
               </documentation>
            </annotation>
         </attribute>
         <attribute name="name" type="string">
            <annotation>
               <documentation>
                  An optional name of the extension instance.
               </documentation>
               <appinfo>
                  <meta.attribute translatable="true"/>
               </appinfo>
            </annotation>
         </attribute>
      </complexType>
   </element>

   <element name="endpoint">
      <annotation>
         <documentation>
            Contributes a single MCP endpoint provider. The class attribute must implement
            com.servoy.eclipse.opencode.IMcpEndpointProvider.
         </documentation>
      </annotation>
      <complexType>
         <attribute name="class" type="string" use="required">
            <annotation>
               <documentation>
                  Fully qualified name of the class implementing
                  com.servoy.eclipse.opencode.IMcpEndpointProvider.
               </documentation>
               <appinfo>
                  <meta.attribute kind="java" basedOn=":com.servoy.eclipse.opencode.IMcpEndpointProvider"/>
               </appinfo>
            </annotation>
         </attribute>
      </complexType>
   </element>

   <annotation>
      <appinfo>
         <meta.section type="since"/>
      </appinfo>
      <documentation>
         2026.06
      </documentation>
   </annotation>

   <annotation>
      <appinfo>
         <meta.section type="examples"/>
      </appinfo>
      <documentation>
         &lt;pre&gt;
&lt;extension point=&quot;com.servoy.eclipse.opencode.mcpEndpoint&quot;&gt;
    &lt;endpoint class=&quot;com.example.MyMcpEndpointProvider&quot;/&gt;
&lt;/extension&gt;
         &lt;/pre&gt;
      </documentation>
   </annotation>

   <annotation>
      <appinfo>
         <meta.section type="apiinfo"/>
      </appinfo>
      <documentation>
         The contributed class must implement
         com.servoy.eclipse.opencode.IMcpEndpointProvider.
      </documentation>
   </annotation>

   <annotation>
      <appinfo>
         <meta.section type="copyright"/>
      </appinfo>
      <documentation>
         Copyright (C) 1997-2026 Servoy BV. Licensed under AGPL v3.
      </documentation>
   </annotation>

</schema>
