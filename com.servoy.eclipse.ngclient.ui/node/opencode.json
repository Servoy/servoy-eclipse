    },
    "time": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/time"
    },
    "memory": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/memory"
    },
    "eclipse-coder": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-coder"
    },
    "eclipse-runner": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-runner"
    },
