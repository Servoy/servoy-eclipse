{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "sdd": {
      "description": "Run full Spec-Driven Development pipeline for a Jira issue",
      "template": "Load the 'sdd' skill and execute the full SDD pipeline for: $ARGUMENTS"
    }
  },
  "mcp": {
    "eclipse-ide": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-ide"
    },
    "time": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/time"
    },
    "memory": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/memory"
    },
    "eclipse-coder": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-coder"
    },
    "eclipse-runner": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-runner"
    },
    "eclipse-context": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-context"
    },
    "eclipse-git": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-git"
    },
    "eclipse-pde": {
      "type": "remote",
      "url": "http://localhost:8086/mcp/eclipse-pde"
    }
  }
}
